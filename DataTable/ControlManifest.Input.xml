<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="lsp" constructor="DataTable" version="1.0.4" 
           display-name-key="DataTable" 
           description-key="DataTable" 
           control-type="standard">
    
    <!-- Dataset Definition -->
    <data-set name="dataSet" display-name-key="Dataset_Display_Key" cds-data-set-options="displayCommandBar:true;displayViewSelector:true;displayQuickFindSearch:true">
      <property-set name="samplePropertySet" display-name-key="Property_Display_Key" description-key="Property_Desc_Key" of-type="SingleLine.Text" usage="bound" required="true" />
    </data-set>
    
    <!-- Properties -->
    <property name="enableSorting" display-name-key="EnableSorting" 
              description-key="EnableSorting_Desc" 
              of-type="TwoOptions" 
              usage="input" 
              required="false" 
              default-value="true" />
    
    <property name="enableFiltering" display-name-key="EnableFiltering" 
              description-key="EnableFiltering_Desc" 
              of-type="TwoOptions" 
              usage="input" 
              required="false" 
              default-value="true" />
    
    <property name="enablePaging" display-name-key="EnablePaging" 
              description-key="EnablePaging_Desc" 
              of-type="TwoOptions" 
              usage="input" 
              required="false" 
              default-value="true" />
    
    <property name="pageSize" display-name-key="PageSize" 
              description-key="PageSize_Desc" 
              of-type="Whole.None" 
              usage="input" 
              required="false" 
              default-value="10" />
    
    <property name="enableSelection" display-name-key="EnableSelection" 
              description-key="EnableSelection_Desc" 
              of-type="TwoOptions" 
              usage="input" 
              required="false" 
              default-value="true" />
    
    <property name="enableMultiSelect" display-name-key="EnableMultiSelect" 
              description-key="EnableMultiSelect_Desc" 
              of-type="TwoOptions" 
              usage="input" 
              required="false" 
              default-value="true" />
    
    <property name="highlightColor" display-name-key="HighlightColor" 
              description-key="HighlightColor_Desc" 
              of-type="SingleLine.Text" 
              usage="input" 
              required="false" 
              default-value="#0078d4" />
    
    <property name="rowHeight" display-name-key="RowHeight" 
              description-key="RowHeight_Desc" 
              of-type="Whole.None" 
              usage="input" 
              required="false" 
              default-value="40" />
    
    <resources>
      <code path="index.ts" order="1"/>
      <css path="css/DataTable.css" order="1" />
    </resources>
    
    <feature-usage>
      <uses-feature name="Utility" required="true" />
      <uses-feature name="WebAPI" required="false" />
    </feature-usage>
  </control>
</manifest>